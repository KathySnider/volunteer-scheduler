# =============================================================================
# AARP Volunteer Scheduler — Environment Configuration
# Copy this file to .env and fill in values for your environment.
#
# Docker secrets (stored as plain-text files, NOT in .env):
#   secret_postgres_pw.txt    — PostgreSQL password
#   secret_db_url.txt         — PostgreSQL connection URL ("database_password" is placeholder)
#   secret_resend_api_key.txt — Resend API key (required when USE_RESEND=true)
#
# See docker-compose.yml for how secrets are mounted into containers.
# =============================================================================


# =============================================================================
# APPLICATION
# =============================================================================

# Application environment. Set to "production" to force Resend email transport
# regardless of the USE_RESEND setting.
APP_ENV=development

# Base URL of the frontend application. Used to build magic link callback URLs
# in outgoing emails. No trailing slash.
APP_URL=http://localhost:3000

# Path on the frontend where magic link tokens are consumed.
# The full callback URL will be: APP_URL + MAGIC_LINK_CALLBACK_PATH + ?token=...
# Your frontend must have a page at this path.
MAGIC_LINK_CALLBACK_PATH=/auth/magic-link


# =============================================================================
# DATABASE
# =============================================================================

# Database name (used by the migration runner).
DB_NAME=volunteer-scheduler

# Path to the migrations directory.
# In Docker:             file:///app/migrations
# Locally (project root): file://migrations
MIGRATIONS_PATH=file://migrations


# =============================================================================
# SESSION
# =============================================================================

# Session token lifetime in seconds. Default: 2592000 (30 days).
SESSION_MAX_AGE=2592000


# =============================================================================
# EMAIL
# =============================================================================

# From address for all outgoing emails.
# May include a display name: "AARP Volunteer System <noreply@example.org>"
EMAIL_FROM=AARP Volunteer System <noreply@example.org>

# Set to "true" to use the Resend API for email delivery.
# Automatically true when APP_ENV=production.
# Requires secret_resend_api_key.txt to be populated.
# When false, emails are sent via Mailhog (local dev/test only).
USE_RESEND=false

# Mailhog SMTP settings — local development and automated testing only.
# Ignored when USE_RESEND=true or APP_ENV=production.
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=1025


# =============================================================================
# FRONTEND — GraphQL endpoint URLs
# NEXT_PUBLIC_ prefix makes these available in the browser bundle.
# For production, replace localhost:8080 with your API's public hostname.
# =============================================================================

NEXT_PUBLIC_GRAPHQL_AUTH_URL=http://localhost:8080/graphql/auth
NEXT_PUBLIC_GRAPHQL_VOLUNTEER_URL=http://localhost:8080/graphql/volunteer
NEXT_PUBLIC_GRAPHQL_ADMIN_URL=http://localhost:8080/graphql/admin
